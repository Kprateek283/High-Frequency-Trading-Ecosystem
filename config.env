# One config source for the whole ecosystem: bash sources it, C++ getenv()s it,
# Python reads os.environ. Defaults live in code; anything set here overrides.
# KEY=value only — no quoting, no expansion; this file is both sourced by bash
# and parsed line-by-line by other consumers.

# --- Network endpoints ---
TCP_PORT=9091                 # exchange order-entry gateway (OUCH/TCP)
MULTICAST_GROUP=239.255.0.1   # market-data (ITCH) multicast group
MULTICAST_PORT=12345          # market-data multicast port

# --- Engine topology ---
NUM_SHARDS=4                  # matching-engine shards (compile-time in exchange.cpp)
GATEWAY_THREADS=4             # SO_REUSEPORT gateway workers (read by exchange + firm)

# --- CPU core map ---
# Reference box has 16 logical CPUs with isolcpus=2,4,6,10,12,14 (nproc reports
# 10 because isolated CPUs are excluded from the shell's affinity mask). Adjust
# both this map and the isolcpus boot parameter together for other hardware.
# Comma-separated, indexed by worker/shard number. Gateway workers pin per 3.2.
GATEWAY_CORES=1,3,5,7         # one per gateway worker  (live: read in worker_loop)
ENGINE_CORES=2,4,6,8         # one per engine shard    (reserved: still hardcoded)
AUX_CORES=0,9                # publisher, order_manager (reserved: still hardcoded)

# --- Paths ---
AUDIT_LOG_PATH=order_audit.log        # engine writes; monitor tails (reserved)
STATS_SHM_PATH=/dev/shm/hft_stats     # Phase 4 seqlock stats region (reserved)
